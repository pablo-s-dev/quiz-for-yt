{
	"manifest_version": 3,
	"name": "Quiz for YouTube",
	"description": "AI-powered quiz generator for YouTube videos. Test your knowledge with automatically generated questions from any video.",
	"version": "1.3.0",
	"permissions": [
		"storage",
		"activeTab"
	],
	"host_permissions": [
		"https://*.youtube.com/*",
		"https://api.openai.com/*",
		"https://chatgpt.com/*",
		"https://chat.openai.com/*"
	],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"https://*.youtube.com/*"
			],
			"js": [
				"ui-kit.js",
				"content.js"
			],
			"css": [
				"main.css"
			]
		},
		{
			"matches": [
				"https://chatgpt.com/*",
				"https://chat.openai.com/*"
			],
			"js": [
				"chatgpt_content.js"
			],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_title": "Quiz for YouTube",
		"default_popup": "popup.html",
		"default_icon": {
			"128": "default_icon.png"
		}
	},
	"icons": {
		"128": "default_icon.png"
	}
}